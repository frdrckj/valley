{
  "name": "valley",
  "private": true,
  "version": "0.3.5",
  "type": "module",
  "description": "Valley — a lightweight, AI-aware desktop terminal for macOS",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
