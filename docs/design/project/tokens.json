{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Valley Design System — W3C design tokens. Drop directly into Tailwind v4 @theme via your token pipeline.",

  "color": {
    "$type": "color",

    "gruvbox": {
      "dark": {
        "bg": {
          "0": { "$value": "#1d2021", "$description": "hard bg" },
          "1": { "$value": "#282828", "$description": "default bg" },
          "2": { "$value": "#3c3836" },
          "3": { "$value": "#504945" },
          "4": { "$value": "#665c54" }
        },
        "fg": {
          "0":     { "$value": "#fbf1c7" },
          "1":     { "$value": "#ebdbb2" },
          "2":     { "$value": "#d5c4a1" },
          "muted": { "$value": "#a89984" }
        },
        "red":    { "$value": "#fb4934" },
        "green":  { "$value": "#b8bb26" },
        "yellow": { "$value": "#fabd2f" },
        "blue":   { "$value": "#83a598" },
        "purple": { "$value": "#d3869b" },
        "aqua":   { "$value": "#8ec07c" },
        "orange": { "$value": "#fe8019" }
      },

      "light": {
        "bg": {
          "0": { "$value": "#f9f5d7", "$description": "hard bg (Light Hard)" },
          "1": { "$value": "#fbf1c7", "$description": "default bg" },
          "2": { "$value": "#ebdbb2" },
          "3": { "$value": "#d5c4a1" },
          "4": { "$value": "#bdae93" }
        },
        "fg": {
          "0":     { "$value": "#1d2021" },
          "1":     { "$value": "#282828" },
          "2":     { "$value": "#3c3836" },
          "muted": { "$value": "#7c6f64" }
        },
        "red":    { "$value": "#9d0006" },
        "green":  { "$value": "#79740e" },
        "yellow": { "$value": "#b57614" },
        "blue":   { "$value": "#076678" },
        "purple": { "$value": "#8f3f71" },
        "aqua":   { "$value": "#427b58" },
        "orange": { "$value": "#af3a03" }
      }
    },

    "semantic": {
      "$description": "Theme-agnostic aliases. Each resolves to dark or light scale via [data-theme].",
      "dark": {
        "surface":           { "$value": "{color.gruvbox.dark.bg.1}" },
        "surface.base":      { "$value": "{color.gruvbox.dark.bg.0}" },
        "surface.elevated":  { "$value": "{color.gruvbox.dark.bg.2}" },
        "surface.hover":     { "$value": "{color.gruvbox.dark.bg.3}" },
        "border.subtle":     { "$value": "{color.gruvbox.dark.bg.3}" },
        "border.strong":     { "$value": "{color.gruvbox.dark.bg.4}" },
        "text.primary":      { "$value": "{color.gruvbox.dark.fg.1}" },
        "text.strong":       { "$value": "{color.gruvbox.dark.fg.0}" },
        "text.muted":        { "$value": "{color.gruvbox.dark.fg.muted}" },
        "accent.primary":    { "$value": "{color.gruvbox.dark.yellow}" },
        "accent.danger":     { "$value": "{color.gruvbox.dark.red}" },
        "accent.success":    { "$value": "{color.gruvbox.dark.green}" },
        "accent.info":       { "$value": "{color.gruvbox.dark.blue}" },
        "accent.warning":    { "$value": "{color.gruvbox.dark.orange}" },
        "accent.ai":         { "$value": "{color.gruvbox.dark.purple}" }
      },
      "light": {
        "surface":           { "$value": "{color.gruvbox.light.bg.1}" },
        "surface.base":      { "$value": "{color.gruvbox.light.bg.0}" },
        "surface.elevated":  { "$value": "{color.gruvbox.light.bg.2}" },
        "surface.hover":     { "$value": "{color.gruvbox.light.bg.2}" },
        "border.subtle":     { "$value": "{color.gruvbox.light.bg.3}" },
        "border.strong":     { "$value": "{color.gruvbox.light.bg.4}" },
        "text.primary":      { "$value": "{color.gruvbox.light.fg.1}" },
        "text.strong":       { "$value": "{color.gruvbox.light.fg.0}" },
        "text.muted":        { "$value": "{color.gruvbox.light.fg.muted}" },
        "accent.primary":    { "$value": "{color.gruvbox.light.yellow}" },
        "accent.danger":     { "$value": "{color.gruvbox.light.red}" },
        "accent.success":    { "$value": "{color.gruvbox.light.green}" },
        "accent.info":       { "$value": "{color.gruvbox.light.blue}" },
        "accent.warning":    { "$value": "{color.gruvbox.light.orange}" },
        "accent.ai":         { "$value": "{color.gruvbox.light.purple}" }
      }
    }
  },

  "font": {
    "family": {
      "mono": {
        "$type": "fontFamily",
        "$value": ["Geist Mono", "JetBrains Mono", "SF Mono", "ui-monospace", "Menlo", "Consolas", "monospace"]
      }
    },
    "weight": {
      "$type": "fontWeight",
      "regular":  { "$value": 400 },
      "medium":   { "$value": 500 },
      "semibold": { "$value": 600 }
    },
    "size": {
      "$type": "dimension",
      "xs":   { "$value": "11px" },
      "sm":   { "$value": "12px" },
      "base": { "$value": "13px", "$description": "default UI text" },
      "md":   { "$value": "14px" },
      "lg":   { "$value": "16px" },
      "xl":   { "$value": "20px" },
      "2xl":  { "$value": "24px" },
      "3xl":  { "$value": "32px" }
    },
    "lineHeight": {
      "$type": "number",
      "terminal": { "$value": 1.0, "$description": "terminal grid — no extra leading" },
      "ui":       { "$value": 1.3 },
      "prose":    { "$value": 1.5 }
    },
    "tracking": {
      "$type": "dimension",
      "tight":  { "$value": "-0.01em" },
      "normal": { "$value": "0em" },
      "loose":  { "$value": "0.02em" }
    }
  },

  "space": {
    "$type": "dimension",
    "0":  { "$value": "0px" },
    "1":  { "$value": "2px" },
    "2":  { "$value": "4px" },
    "3":  { "$value": "6px" },
    "4":  { "$value": "8px" },
    "5":  { "$value": "12px" },
    "6":  { "$value": "16px" },
    "7":  { "$value": "20px" },
    "8":  { "$value": "24px" },
    "9":  { "$value": "32px" },
    "10": { "$value": "48px" }
  },

  "radius": {
    "$type": "dimension",
    "none": { "$value": "0px" },
    "sm":   { "$value": "4px" },
    "md":   { "$value": "6px", "$description": "default UI radius" },
    "lg":   { "$value": "8px" },
    "xl":   { "$value": "12px" }
  },

  "motion": {
    "duration": {
      "$type": "duration",
      "instant": { "$value": "0ms" },
      "fast":    { "$value": "120ms" },
      "normal":  { "$value": "200ms" },
      "slow":    { "$value": "320ms" }
    },
    "easing": {
      "$type": "cubicBezier",
      "standard": { "$value": [0.2, 0.8, 0.2, 1] }
    }
  },

  "shadow": {
    "$type": "shadow",
    "none":     { "$value": "none" },
    "floating": {
      "$value": "0 2px 6px rgba(0,0,0,0.30), 0 12px 32px rgba(0,0,0,0.45)",
      "$description": "Use ONLY on floating surfaces — omnibar, dropdowns, popovers."
    }
  }
}
